    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="System.out.println(&quot;==== SYNCRONIZING DATA ===&quot;);&#xD;&#xA;System.out.println(&quot;ID => &quot; + globalMap.get(&quot;id_proposta&quot;));&#xD;&#xA;System.out.println(&quot;NUMBER (OCS) => &quot; + globalMap.get(&quot;num_pratica_ocs&quot;));&#xD;&#xA;System.out.println(&quot;TYPE => &quot; + globalMap.get(&quot;procedura&quot;));&#xD;&#xA;System.out.println(&quot;=================================================&quot;);&#xD;&#xA;String body = new StringBuilder(&quot;FFun=4&amp;&quot;)&#xD;&#xA;.append(&quot;FIdPro=%s&amp;&quot;.formatted((String) globalMap.get(&quot;id_proposta&quot;)))&#xD;&#xA;.append(&quot;FStaOCS=%s&amp;&quot;.formatted((String) globalMap.get(&quot;stato&quot;)))&#xD;&#xA;.append(&quot;FAttOCS=%s&amp;&quot;.formatted((String) globalMap.get(&quot;attributo&quot;)))&#xD;&#xA;.append(&quot;FNumPra=%s&amp;&quot;.formatted((String) globalMap.get(&quot;num_pratica_ocs&quot;)))&#xD;&#xA;.append(&quot;FStaBDP=%s&amp;&quot;.formatted(&quot;2&quot;)) // constant &#xD;&#xA;.append(&quot;FIndCarBDP=%s&amp;&quot;.formatted(&quot;0&quot;)) // constant&#xD;&#xA;.append(&quot;FDontChangeProStatus=%s&amp;&quot;.formatted(&quot;1&quot;)) // constant&#xD;&#xA;.append(&quot;FDate=%s&amp;&quot;.formatted((String) globalMap.get(&quot;data&quot;)))&#xD;&#xA;.append(&quot;FTime=%s&amp;&quot;.formatted((String) globalMap.get(&quot;ora&quot;)))&#xD;&#xA;.append(&quot;FACCodice=%s&amp;&quot;.formatted(row10.CODICE_VENDITORE))&#xD;&#xA;.toString();&#xD;&#xA;globalMap.put(&quot;restPayload&quot;, body);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
