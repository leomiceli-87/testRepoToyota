  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="680" posY="1080">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_8" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="System.out.println(&quot;==== EXTRACTING LIQUIDATION and PERSONAL Data ===&quot;);&#xD;&#xA;System.out.println(&quot;ID => &quot; + globalMap.get(&quot;id_proposta&quot;));&#xD;&#xA;System.out.println(&quot;NUMBER (OCS) => &quot; + globalMap.get(&quot;num_pratica_ocs&quot;));&#xD;&#xA;System.out.println(&quot;TYPE => &quot; + globalMap.get(&quot;procedura&quot;));&#xD;&#xA;System.out.println(&quot;=================================================&quot;);&#xD;&#xA;String state = ((String) globalMap.get(&quot;stato&quot;)),&#xD;&#xA;&#x9;   type = null, &#xD;&#xA;&#x9;   query = null,&#xD;&#xA;&#x9;   tableName = null;&#xD;&#xA;if (state.equals(&quot;40&quot;)) {&#xD;&#xA;&#x9;type = &quot;LOAN&quot;;&#xD;&#xA;&#x9;tableName = &quot;PLPRATAS&quot;;&#xD;&#xA;&#x9;query = &quot;&quot;&quot;&#xD;&#xA;&#x9;&#x9;&#x9;SELECT &#xD;&#xA;&#x9;&#x9;&#x9;    PLPRATAS.PLCAS_DATA_DEST AS DATA_DESTINAZIONE_PAGAMENTO,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRATAS.PLCAS_DEST_IMP_VALUTA AS IMPORTO_LIQUIDAZIONE,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRATAS.PAGAMENTO AS TIPO_PAGAMENTO,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRATAS.ABI AS ABI_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRATAS.CAB AS CAB_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRATAS.NUMERO_CC AS NUMERO_CONTO_CORRENTE_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWABI.ABI_DENOMINAZIONE AS NOME_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWCAB.CAB_AGENZIA AS AGENZIA_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWCAB.CAB_INDIRIZZO AS INDIRIZZO_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWCAB.CAB_LOCALITA AS LOCALITA_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRAT.PLC_VENDITORE AS CODICE_VENDITORE,&#xD;&#xA;&#x9;&#x9;&#x9;    CCANAGR.AC_NOME AS NOME_VENDITORE,&#xD;&#xA;&#x9;&#x9;&#x9;    CCANAGR.AC_COGNOME AS COGNOME_VENDITORE,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRAT.PLC_AUTO_TARGA AS TARGA_VEICOLO,&#xD;&#xA;&#x9;&#x9;&#x9;    PLPRAT.PLC_AUTO_TELAIO AS TELAIO_VEICOLO,&#xD;&#xA;&#x9;&#x9;&#x9;    OXCTFPAFD.OXCTPAFD_DATA_SCADENZA AS DATA_SCADENZA_RATA&#xD;&#xA;&#x9;&#x9;&#x9;FROM PLPRATAS&#xD;&#xA;&#x9;&#x9;&#x9;INNER JOIN PLPRAT ON PLPRATAS.PLCAS_NUM_PRATICA = PLPRAT.PLC_NUM_PRATICA&#xD;&#xA;&#x9;&#x9;&#x9;LEFT JOIN CCNEWABI ON PLPRATAS.ABI = CCNEWABI.ABI_ABI&#xD;&#xA;&#x9;&#x9;&#x9;LEFT JOIN CCNEWCAB ON PLPRATAS.ABI = CCNEWCAB.CAB_ABI &#xD;&#xA;&#x9;&#x9;&#x9;    AND PLPRATAS.CAB = CCNEWCAB.CAB_CAB&#xD;&#xA;&#x9;&#x9;&#x9;LEFT JOIN CCANAGR ON PLPRAT.PLC_VENDITORE = CCANAGR.AC_CODICE&#xD;&#xA;&#x9;&#x9;&#x9;LEFT JOIN OXCTFPAFD ON PLPRAT.PLC_NUM_PRATICA = OXCTFPAFD.OXCTPAFD_NUM_PRATICA&#xD;&#xA;&#x9;&#x9;&#x9;    AND OXCTFPAFD.OXCTPAFD_PROCEDURA =  '%s'&#xD;&#xA;&#x9;&#x9;&#x9;    AND OXCTFPAFD.OXCTPAFD_TIPO_RATA = 'R'&#xD;&#xA;&#x9;&#x9;&#x9;    AND OXCTFPAFD.OXCTPAFD_NUMERO_RATA = 1&#xD;&#xA;&#x9;&#x9;&#x9;WHERE PLPRATAS.PLCAS_NUM_PRATICA = '%s'&#xD;&#xA;&#x9;&#x9;&#x9;AND PLPRATAS.PLCAS_TIPO_LIQUIDAZIONE = 'S';&#xD;&#xA;&#x9;&#x9;&quot;&quot;&quot;.formatted(&#xD;&#xA;&#x9;&#x9;(String) globalMap.get(&quot;procedura&quot;),&#xD;&#xA;&#x9;&#x9;(String) globalMap.get(&quot;num_pratica_ocs&quot;))&#xD;&#xA;&#x9;&#x9;.trim();&#xD;&#xA;} else if (state.equals(&quot;25&quot;)) {&#xD;&#xA;&#x9;type = &quot;LEASING&quot;;&#xD;&#xA;&#x9;tableName = &quot;LECES&quot;;&#xD;&#xA;&#x9;query = &quot;&quot;&quot;&#xD;&#xA;&#x9;&#x9;&#x9;SELECT &#xD;&#xA;&#x9;&#x9;&#x9;    LECES.LCE_DATA_PAGAMENTO AS DATA_DESTINAZIONE_PAGAMENTO,    &#xD;&#xA;&#x9;&#x9;&#x9;    LECES.LCE_VALUTA AS IMPORTO_LIQUIDAZIONE, &#xD;&#xA;&#x9;&#x9;&#x9;    NULL AS TIPO_PAGAMENTO,&#xD;&#xA;&#x9;&#x9;&#x9;    LECES.LCE_ABI AS ABI_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    LECES.LCE_CAB AS CAB_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    LECES.LCE_CC AS NUMERO_CONTO_CORRENTE_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWABI.ABI_DENOMINAZIONE AS NOME_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWCAB.CAB_AGENZIA AS AGENZIA_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWCAB.CAB_INDIRIZZO AS INDIRIZZO_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    CCNEWCAB.CAB_LOCALITA AS LOCALITA_BANCA,&#xD;&#xA;&#x9;&#x9;&#x9;    LEPRA.LPC_CODICE_VENDITORE AS CODICE_VENDITORE,&#xD;&#xA;&#x9;&#x9;&#x9;    CCANAGR.AC_NOME AS NOME_VENDITORE,&#xD;&#xA;&#x9;&#x9;&#x9;    CCANAGR.AC_COGNOME AS COGNOME_VENDITORE,&#xD;&#xA;&#x9;&#x9;&#x9;    LECES.LCE_TARGA AS TARGA_VEICOLO,&#xD;&#xA;&#x9;&#x9;&#x9;    LECES.LCE_TELAIO AS TELAIO_VEICOLO,&#xD;&#xA;&#x9;&#x9;&#x9;    LEPAM.LRA_DATA_SCADENZA AS DATA_SCADENZA_RATA&#xD;&#xA;&#x9;&#x9;&#x9;FROM LECES&#xD;&#xA;&#x9;&#x9;&#x9;INNER JOIN LEPRA ON LECES.LCE_NUM_PRATICA = LEPRA.LPC_NUM_PRATICA&#xD;&#xA;&#x9;&#x9;&#x9;LEFT JOIN CCNEWABI ON LECES.LCE_ABI = CCNEWABI.ABI_ABI&#xD;&#xA;&#x9;&#x9;&#x9;LEFT JOIN CCNEWCAB ON LECES.LCE_ABI = CCNEWCAB.CAB_ABI &#xD;&#xA;&#x9;&#x9;&#x9;    AND LECES.LCE_CAB = CCNEWCAB.CAB_CAB&#xD;&#xA;&#x9;&#x9;&#x9;LEFT JOIN CCANAGR ON LEPRA.LPC_CODICE_VENDITORE = CCANAGR.AC_CODICE&#xD;&#xA;&#x9;&#x9;&#x9;INNER JOIN LEPAM ON LECES.LCE_NUM_PRATICA = LEPAM.LRA_NUM_PRATICA&#xD;&#xA;&#x9;&#x9;&#x9;    AND LEPAM.LRA_NUMERO_RATA = 1&#xD;&#xA;&#x9;&#x9;&#x9;WHERE LECES.LCE_NUM_PRATICA = '%s'&#xD;&#xA;&#x9;&#x9;&#x9;AND LECES.LCE_CESPITE = 1;&#xD;&#xA;&#x9;&#x9;&quot;&quot;&quot;.formatted((String) globalMap.get(&quot;num_pratica_ocs&quot;))&#xD;&#xA;&#x9;&#x9;.trim();&#xD;&#xA;} else {&#xD;&#xA;&#x9;throw new IllegalStateException(&quot;The State of Dossier [%s] is not valid !&quot;.formatted(globalMap.get(&quot;id_proposta&quot;)));&#xD;&#xA;}&#xD;&#xA;globalMap.put(&quot;tableName&quot;, tableName);&#xD;&#xA;globalMap.put(&quot;query&quot;, query);&#xD;&#xA;System.out.println(&quot;==== INQUIRING the DATABASE ===&quot;);&#xD;&#xA;System.out.println(&quot;ID => &quot; + globalMap.get(&quot;id_proposta&quot;));&#xD;&#xA;System.out.println(&quot;NUMBER (OCS) => &quot; + globalMap.get(&quot;num_pratica_ocs&quot;));&#xD;&#xA;System.out.println(&quot;TYPE => &quot; + type);&#xD;&#xA;System.out.println(&quot;TABLE => &quot; + tableName);&#xD;&#xA;System.out.println(&quot;===============================&quot;);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_8"/>
