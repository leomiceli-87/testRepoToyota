  <node componentName="tAS400Input" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="480" posY="680">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBInput_3" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1"/>
    <elementParameter field="CLOSED_LIST" name="DB_VERSION" value="jt400-20.0.7.jar" show="false"/>
    <elementParameter field="TEXT" name="HOST" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="AS400" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:+RDd1Kwt+hheCRsjouDt1FAPP8uSLq0h/Bu4nKqU" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;WITH PARAMETRI AS (&#xD;&#xA;    SELECT&#xD;&#xA;        VARCHAR_FORMAT(CURRENT DATE, 'YYYYMMDD') AS DATA_ODIERNA,&#xD;&#xA;        INTEGER(VARCHAR_FORMAT(CURRENT TIMESTAMP - 30 MINUTES, 'HH24MISS')) AS ORA_LIMITE&#xD;&#xA;    FROM SYSIBM.SYSDUMMY1&#xD;&#xA;)&#xD;&#xA;SELECT &#xD;&#xA;    'CO' AS PROCEDURA, &#xD;&#xA;    PLPRATST.PLPRA_NUM_PRATICA AS NUM_PRATICA, &#xD;&#xA;    PLPRATST.PLPRA_STATO AS STATO, &#xD;&#xA;    PLPRATST.PLPRA_ATTRIBUTO AS ATTRIBUTO, &#xD;&#xA;    PLPRATST.PLPRA_DATA AS DATA_VAR, &#xD;&#xA;    PLPRATST.PLPRA_TIME AS ORA_VAR, &#xD;&#xA;    PLPRATST.PLPRA_UTENTE AS UTENTE, &#xD;&#xA;    YEAR(DATE('1899-12-30') + PLC_DATA_DECORRENZA DAY) ||&#xD;&#xA;    RIGHT('0' || MONTH(DATE('1899-12-30') + PLC_DATA_DECORRENZA DAY), 2) ||&#xD;&#xA;    RIGHT('0' || DAY(DATE('1899-12-30') + PLC_DATA_DECORRENZA DAY), 2) &#xD;&#xA;        AS DATA_DECORRENZA&#xD;&#xA;FROM PLPRATST&#xD;&#xA;LEFT OUTER JOIN PLPRAT &#xD;&#xA;    ON PLPRAT.PLC_NUM_PRATICA = PLPRA_NUM_PRATICA&#xD;&#xA;CROSS JOIN PARAMETRI&#xD;&#xA;WHERE PLPRATST.PLPRA_DATA = PARAMETRI.DATA_ODIERNA&#xD;&#xA;AND PLPRATST.PLPRA_TIME >= PARAMETRI.ORA_LIMITE&#xD;&#xA;UNION ALL&#xD;&#xA;SELECT &#xD;&#xA;    'LE' AS PROCEDURA, &#xD;&#xA;    LEPRALOGST.LPCST_NUM_PRATICA AS NUM_PRATICA, &#xD;&#xA;    LEPRALOGST.LPCST_STATO AS STATO, &#xD;&#xA;    LEPRALOGST.LPCST_ATTRIBUTO AS ATTRIBUTO, &#xD;&#xA;    LEPRALOGST.LPCST_DATA_SYS AS DATA_VAR, &#xD;&#xA;    LEPRALOGST.LPCST_ORA_SYS AS ORA_VAR, &#xD;&#xA;    LEPRALOGST.LPCST_OPERATORE AS UTENTE, &#xD;&#xA;    YEAR(DATE('1899-12-30') + LPC_DATA_DECORRENZA DAY) ||&#xD;&#xA;    RIGHT('0' || MONTH(DATE('1899-12-30') + LPC_DATA_DECORRENZA DAY), 2) ||&#xD;&#xA;    RIGHT('0' || DAY(DATE('1899-12-30') + LPC_DATA_DECORRENZA DAY), 2)&#xD;&#xA;        AS DATA_DECORRENZA&#xD;&#xA;FROM LEPRALOGST&#xD;&#xA;LEFT OUTER JOIN LEPRA &#xD;&#xA;    ON LEPRA.LPC_NUM_PRATICA = LEPRALOGST.LPCST_NUM_PRATICA&#xD;&#xA;CROSS JOIN PARAMETRI&#xD;&#xA;WHERE LEPRALOGST.LPCST_DATA_SYS = PARAMETRI.DATA_ODIERNA&#xD;&#xA;AND LEPRALOGST.LPCST_ORA_SYS >= PARAMETRI.ORA_LIMITE&quot;"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="as400_id" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;prompt=false&quot;" show="false"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
    <elementParameter field="TECHNICAL" name="ENCODING:ENCODING_TYPE" value="ISO-8859-15"/>
    <elementParameter field="CHECK" name="TRIM_ALL_COLUMN" value="false"/>
    <elementParameter field="TABLE" name="TRIM_COLUMN">
      <elementValue elementRef="SCHEMA_COLUMN" value="PROCEDURA" id="0"/>
      <elementValue elementRef="TRIM" value="false" id="1"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="NUM_PRATICA" id="2"/>
      <elementValue elementRef="TRIM" value="false" id="3"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="STATO" id="4"/>
      <elementValue elementRef="TRIM" value="false" id="5"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="ATTRIBUTO" id="6"/>
      <elementValue elementRef="TRIM" value="false" id="7"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="DATA_VAR" id="8"/>
      <elementValue elementRef="TRIM" value="false" id="9"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="ORA_VAR" id="10"/>
      <elementValue elementRef="TRIM" value="false" id="11"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="UTENTE" id="12"/>
      <elementValue elementRef="TRIM" value="false" id="13"/>
    </elementParameter>
    <elementParameter field="CHECK" name="SET_QUERY_TIMEOUT" value="false"/>
    <elementParameter field="TEXT" name="QUERY_TIMEOUT_IN_SECONDS" value="30" show="false"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
