    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="WITH PARAMETRI AS (&#xD;&#xA;    SELECT&#xD;&#xA;        VARCHAR_FORMAT(CURRENT DATE, 'YYYYMMDD') AS DATA_ODIERNA,&#xD;&#xA;        INTEGER(VARCHAR_FORMAT(CURRENT TIMESTAMP - 30 MINUTES, 'HH24MISS')) AS ORA_LIMITE&#xD;&#xA;    FROM SYSIBM.SYSDUMMY1&#xD;&#xA;)&#xD;&#xA;SELECT &#xD;&#xA;    'CO' AS PROCEDURA, &#xD;&#xA;    PLPRATST.PLPRA_NUM_PRATICA AS NUM_PRATICA, &#xD;&#xA;    PLPRATST.PLPRA_STATO AS STATO, &#xD;&#xA;    PLPRATST.PLPRA_ATTRIBUTO AS ATTRIBUTO, &#xD;&#xA;    PLPRATST.PLPRA_DATA AS DATA_VAR, &#xD;&#xA;    PLPRATST.PLPRA_TIME AS ORA_VAR, &#xD;&#xA;    PLPRATST.PLPRA_UTENTE AS UTENTE, &#xD;&#xA;    YEAR(DATE('1899-12-30') + PLC_DATA_DECORRENZA DAY) ||&#xD;&#xA;    RIGHT('0' || MONTH(DATE('1899-12-30') + PLC_DATA_DECORRENZA DAY), 2) ||&#xD;&#xA;    RIGHT('0' || DAY(DATE('1899-12-30') + PLC_DATA_DECORRENZA DAY), 2) &#xD;&#xA;        AS DATA_DECORRENZA&#xD;&#xA;FROM PLPRATST&#xD;&#xA;LEFT OUTER JOIN PLPRAT &#xD;&#xA;    ON PLPRAT.PLC_NUM_PRATICA = PLPRA_NUM_PRATICA&#xD;&#xA;CROSS JOIN PARAMETRI&#xD;&#xA;WHERE PLPRATST.PLPRA_DATA = PARAMETRI.DATA_ODIERNA&#xD;&#xA;AND PLPRATST.PLPRA_TIME >= PARAMETRI.ORA_LIMITE&#xD;&#xA;UNION ALL&#xD;&#xA;SELECT &#xD;&#xA;    'LE' AS PROCEDURA, &#xD;&#xA;    LEPRALOGST.LPCST_NUM_PRATICA AS NUM_PRATICA, &#xD;&#xA;    LEPRALOGST.LPCST_STATO AS STATO, &#xD;&#xA;    LEPRALOGST.LPCST_ATTRIBUTO AS ATTRIBUTO, &#xD;&#xA;    LEPRALOGST.LPCST_DATA_SYS AS DATA_VAR, &#xD;&#xA;    LEPRALOGST.LPCST_ORA_SYS AS ORA_VAR, &#xD;&#xA;    LEPRALOGST.LPCST_OPERATORE AS UTENTE, &#xD;&#xA;    YEAR(DATE('1899-12-30') + LPC_DATA_DECORRENZA DAY) ||&#xD;&#xA;    RIGHT('0' || MONTH(DATE('1899-12-30') + LPC_DATA_DECORRENZA DAY), 2) ||&#xD;&#xA;    RIGHT('0' || DAY(DATE('1899-12-30') + LPC_DATA_DECORRENZA DAY), 2)&#xD;&#xA;        AS DATA_DECORRENZA&#xD;&#xA;FROM LEPRALOGST&#xD;&#xA;LEFT OUTER JOIN LEPRA &#xD;&#xA;    ON LEPRA.LPC_NUM_PRATICA = LEPRALOGST.LPCST_NUM_PRATICA&#xD;&#xA;CROSS JOIN PARAMETRI&#xD;&#xA;WHERE LEPRALOGST.LPCST_DATA_SYS = PARAMETRI.DATA_ODIERNA&#xD;&#xA;AND LEPRALOGST.LPCST_ORA_SYS >= PARAMETRI.ORA_LIMITE"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="as400_id" show="false"/>
