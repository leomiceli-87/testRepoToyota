    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1"/>
    <elementParameter field="CLOSED_LIST" name="DB_VERSION" value="jt400-20.0.7.jar" show="false"/>
    <elementParameter field="TEXT" name="HOST" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="AS400" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:4emk3X8u4ta/g0Yuw9LG6Il8OqMbxTfdpsiGBjwY" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &#xD;&#xA;    t1.OXNOTPR_PROGRESSIVO as PROGRESSIVO,&#xD;&#xA;    t2.OXNOD_TESTO AS NOTA&#xD;&#xA;FROM OXNOFTPR t1&#xD;&#xA;INNER JOIN OXNOFD t2 ON t1.OXNOTPR_PROGRESSIVO = t2.OXNOD_PROGRESSIVO&#xD;&#xA;WHERE t1.OXNOTPR_PROCEDURA = '&quot; + (String) globalMap.get(&quot;procedura&quot;) + &quot;'&#xD;&#xA;  AND t1.OXNOTPR_PRATICA   = '&quot; + (String) globalMap.get(&quot;num_pratica_ocs&quot;) + &quot;'&#xD;&#xA;  AND t1.OXNOTPR_TIPOLOGIA = '&quot; +&#xD;&#xA;      (&#xD;&#xA;        (&#xD;&#xA;          &quot;PRAP&quot;.equals((String) globalMap.get(&quot;procedura&quot;)) &amp;&amp;&#xD;&#xA;          &quot;20&quot;.equals((String) globalMap.get(&quot;stato&quot;)) &amp;&amp;&#xD;&#xA;          (&quot;AP&quot;.equals((String) globalMap.get(&quot;attributo&quot;)) || &quot;SP&quot;.equals((String) globalMap.get(&quot;attributo&quot;)))&#xD;&#xA;        ) ? &quot;PRAP&quot; :&#xD;&#xA;        (&#xD;&#xA;          &quot;PRAP&quot;.equals((String) globalMap.get(&quot;procedura&quot;)) &amp;&amp;&#xD;&#xA;          &quot;05&quot;.equals((String) globalMap.get(&quot;stato&quot;)) &amp;&amp;&#xD;&#xA;          (&#xD;&#xA;            (String) globalMap.get(&quot;attributo&quot;) == null || &#xD;&#xA;            &quot;SP&quot;.equals((String) globalMap.get(&quot;attributo&quot;))&#xD;&#xA;          )&#xD;&#xA;        ) ? &quot;PRAP&quot; :&#xD;&#xA;        (&#xD;&#xA;          &quot;PRAP&quot;.equals((String) globalMap.get(&quot;procedura&quot;)) &amp;&amp;&#xD;&#xA;          &quot;15&quot;.equals((String) globalMap.get(&quot;stato&quot;))&#xD;&#xA;        ) ? &quot;PRAP&quot; :&#xD;&#xA;        (&#xD;&#xA;          &quot;PRAR&quot;.equals((String) globalMap.get(&quot;procedura&quot;)) &amp;&amp;&#xD;&#xA;          &quot;30&quot;.equals((String) globalMap.get(&quot;stato&quot;))&#xD;&#xA;        ) ? &quot;PRAR&quot; :&#xD;&#xA;        (&#xD;&#xA;          &quot;PRSL&quot;.equals((String) globalMap.get(&quot;procedura&quot;)) &amp;&amp;&#xD;&#xA;          &quot;30 LS&quot;.equals((String) globalMap.get(&quot;stato&quot;))&#xD;&#xA;        ) ? &quot;PRSL&quot; :&#xD;&#xA;        (&#xD;&#xA;          &quot;PRLI&quot;.equals((String) globalMap.get(&quot;procedura&quot;)) &amp;&amp;&#xD;&#xA;          &quot;15 LS&quot;.equals((String) globalMap.get(&quot;stato&quot;))&#xD;&#xA;        ) ? &quot;PRLI&quot; :&#xD;&#xA;        &quot;&quot;&#xD;&#xA;      ) + &quot;'&#xD;&#xA;  AND t1.OXNOTPR_ANNULLO &lt;> 'S'&#xD;&#xA;ORDER BY t1.OXNOTPR_PROGRESSIVO DESC, t2.OXNOD_RIGA ASC&quot;"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="as400_id" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;prompt=false&quot;" show="false"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
