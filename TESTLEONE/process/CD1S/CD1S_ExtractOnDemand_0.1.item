t idxCide = -1;&#xD;&#xA;    for (int i = 0; i &lt; headers.length; i++) {&#xD;&#xA;        String h = headers[i].trim();&#xD;&#xA;        if (&quot;doc_chdoctip&quot;.equals(h)) idxTip = i;&#xD;&#xA;        else if (&quot;doc_vcdocpat&quot;.equals(h)) idxPat = i;&#xD;&#xA;        else if (&quot;doc_vcdocfil&quot;.equals(h)) idxFil = i;&#xD;&#xA;        else if (&quot;doc_vcdocide&quot;.equals(h)) idxCide = i;&#xD;&#xA;    }&#xD;&#xA;    for (int r = 3; r &lt; parts.length; r++) {&#xD;&#xA;        String record = parts[r] == null ? &quot;&quot; : parts[r].trim();&#xD;&#xA;        if (record.length() == 0) continue;&#xD;&#xA;        String[] values = record.split(java.util.regex.Pattern.quote(&quot;|F|&quot;), -1);&#xD;&#xA;        String doc_chdoctip = &quot;&quot;;&#xD;&#xA;        String doc_vcdocpat = &quot;&quot;;&#xD;&#xA;        String doc_vcdocfil = &quot;&quot;;&#xD;&#xA;        String doc_vcdocide = &quot;&quot;;&#xD;&#xA;        if (idxTip >= 0 &amp;&amp; idxTip &lt; values.length &amp;&amp; values[idxTip].length() > 0) {&#xD;&#xA;            doc_chdoctip = new String(java.util.Base64.getDecoder().decode(values[idxTip]), &quot;UTF-8&quot;);&#xD;&#xA;        }&#xD;&#xA;        if (idxPat >= 0 &amp;&amp; idxPat &lt; values.length &amp;&amp; values[idxPat].length() > 0) {&#xD;&#xA;            doc_vcdocpat = new String(java.util.Base64.getDecoder().decode(values[idxPat]), &quot;UTF-8&quot;);&#xD;&#xA;        }&#xD;&#xA;        if (idxFil >= 0 &amp;&amp; idxFil &lt; values.length &amp;&amp; values[idxFil].length() > 0) {&#xD;&#xA;            doc_vcdocfil = new String(java.util.Base64.getDecoder().decode(values[idxFil]), &quot;UTF-8&quot;);&#xD;&#xA;        }&#xD;&#xA;        if (idxCide >= 0 &amp;&amp; idxCide &lt; values.length &amp;&amp; values[idxCide].length() > 0) {&#xD;&#xA;            doc_vcdocide = new String(java.util.Base64.getDecoder().decode(values[idxCide]), &quot;UTF-8&quot;);&#xD;&#xA;        }&#xD;&#xA;        java.util.Map&lt;String, String> m = new java.util.HashMap&lt;>();&#xD;&#xA;        m.put(&quot;doc_chdoctip&quot;, doc_chdoctip);&#xD;&#xA;        m.put(&quot;doc_vcdocpat&quot;, doc_vcdocpat);&#xD;&#xA;        m.put(&quot;doc_vcdocfil&quot;, doc_vcdocfil);&#xD;&#xA;        m.put(&quot;doc_vcdocide&quot;, doc_vcdocide);&#xD;&#xA;        lista.add(m);&#xD;&#xA;        globalMap.put(&quot;listaDati&quot;, lista);&#xD;&#xA;    }&#xD;&#xA;}"/>
