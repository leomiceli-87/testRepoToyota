    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="java.util.List&lt;String> rowsList = (java.util.List&lt;String>) globalMap.get(&quot;tHashOutput_1_rowsList&quot;);&#xD;&#xA;StringBuilder jsonBuilder = new StringBuilder();&#xD;&#xA;jsonBuilder.append(&quot;[\n&quot;);&#xD;&#xA;if (rowsList != null &amp;&amp; !rowsList.isEmpty()) {&#xD;&#xA; for (int i = 0; i &lt; rowsList.size(); i++) {&#xD;&#xA;     String row = rowsList.get(i);&#xD;&#xA;     if (i > 0) {&#xD;&#xA;         jsonBuilder.append(&quot;,\n&quot;);&#xD;&#xA;     }&#xD;&#xA;     jsonBuilder.append(&quot;    \&quot;&quot;).append(row.replace(&quot;\&quot;&quot;, &quot;\\\&quot;&quot;)).append(&quot;\&quot;&quot;);&#xD;&#xA; }&#xD;&#xA; jsonBuilder.append(&quot;\n&quot;);&#xD;&#xA;}&#xD;&#xA;jsonBuilder.append(&quot;]&quot;);&#xD;&#xA;String finalJson = jsonBuilder.toString().trim();&#xD;&#xA;globalMap.put(&quot;restPayload&quot;, finalJson);&#xD;&#xA;System.out.println(&quot;Payload generato: &quot; + finalJson);&#xD;&#xA;System.out.println(&quot;Numero di righe: &quot; + (rowsList != null ? rowsList.size() : 0));"/>
