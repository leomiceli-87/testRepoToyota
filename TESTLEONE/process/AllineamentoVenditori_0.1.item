    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String GW_FIELD_SEP = &quot;|F|&quot;;&#xD;&#xA;java.util.Base64.Encoder encoder = java.util.Base64.getEncoder();&#xD;&#xA;String field1 = &quot;ive_codice=&quot; + input_row.ive_codice;&#xD;&#xA;String field2 = &quot;ac_nome=&quot; + input_row.ac_nome;&#xD;&#xA;String field3 = &quot;ac_cognome=&quot; + input_row.ac_cognome;&#xD;&#xA;String encField1 = encoder.encodeToString(field1.getBytes());&#xD;&#xA;String encField2 = encoder.encodeToString(field2.getBytes());&#xD;&#xA;String encField3 = encoder.encodeToString(field3.getBytes());&#xD;&#xA;String formattedRow = &quot;ctf_vrl|&quot; + encField1 + GW_FIELD_SEP + encField2 + GW_FIELD_SEP + encField3;&#xD;&#xA;java.util.List&lt;String> rowsList = (java.util.List&lt;String>) globalMap.get(&quot;tHashOutput_1_rowsList&quot;);&#xD;&#xA;if (rowsList == null) {&#xD;&#xA;    rowsList = new java.util.ArrayList&lt;String>();&#xD;&#xA;    globalMap.put(&quot;tHashOutput_1_rowsList&quot;, rowsList);&#xD;&#xA;}&#xD;&#xA;rowsList.add(formattedRow);"/>
