    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT&#xD;&#xA;AC_CODICE AS ANA_CODICE,&#xD;&#xA;AC_RAG_SOCIALE_1 AS ANA_RAG_SOCIALE,&#xD;&#xA;CONCAT(AC_INDIRIZZO_1, AC_INDIRIZZO_2) AS ANA_INDIRIZZO,&#xD;&#xA;AC_CAP AS ANA_CAP,&#xD;&#xA;AC_FRAZIONE AS ANA_FRAZIONE,&#xD;&#xA;AC_LOCALITA AS ANA_LOCALITA,&#xD;&#xA;AC_PROVINCIA AS ANA_PROVINCIA,&#xD;&#xA;AC_PAESE_ESTERO AS ANA_PAESE_ESTERO,&#xD;&#xA;AC_COD_CAB_COMUNE AS ANA_COD_CAB_COMUNE,&#xD;&#xA;AC_NASCITA_DATA AS ANA_NASCITA_DATA,&#xD;&#xA;AC_NASCITA_LUOGO AS ANA_NASCITA_LUOGO,&#xD;&#xA;AC_NASCITA_PROV AS ANA_NASCITA_PROV,&#xD;&#xA;AC_NASCITA_NAZIONE AS ANA_NASCITA_NAZIONE,&#xD;&#xA;AC_NASCITA_CAB_LOC AS ANA_NASCITA_CAB_LOC,&#xD;&#xA;AC_CITTADINANZA AS ANA_CITTADINANZA,&#xD;&#xA;AC_SESSO AS ANA_SESSO,&#xD;&#xA;AC_TIPO_ANAGRAFICA AS ANA_TIPO_ANAGRAFICA,&#xD;&#xA;AC_FORMA_GIURIDICA AS ANA_FORMA_GIURIDICA,&#xD;&#xA;AC_CODICE_FISCALE AS ANA_CODICE_FISCALE,&#xD;&#xA;AC_PARTITA_IVA AS ANA_PARTITA_IVA,&#xD;&#xA;AC_TELEFONO AS ANA_TELEFONO,&#xD;&#xA;AC_TELEFONO_2 AS ANA_TELEFONO_2,&#xD;&#xA;AC_TELEFONO_CEL AS ANA_TELEFONO_CEL,&#xD;&#xA;AC_TELEFONO_SEDE AS ANA_TELEFONO_SEDE,&#xD;&#xA;AC_FAX AS ANA_FAX,&#xD;&#xA;AC_EMAIL AS ANA_EMAIL,&#xD;&#xA;AC_IDE_TIPO_DOCUMENTO AS ANA_IDE_TIPO_DOCUMENTO,&#xD;&#xA;AC_IDE_NUM_DOCUMENTO AS ANA_IDE_NUM_DOCUMENTO,&#xD;&#xA;AC_IDE_UFFICIO_RILASCIO AS ANA_IDE_UFFICIO_RILASCIO,&#xD;&#xA;AC_IDE_LUOGO_RILASCIO AS ANA_IDE_LUOGO_RILASCIO,&#xD;&#xA;AC_IDE_PROV_RILASCIO AS ANA_IDE_PROV_RILASCIO,&#xD;&#xA;AC_IDE_DATA_RILASCIO AS ANA_IDE_DATA_RILASCIO,&#xD;&#xA;AC_IDE_DATA_SCADENZA AS ANA_IDE_DATA_SCADENZA,&#xD;&#xA;AC_SOTTOGRUPPO AS ANA_SOTTOGRUPPO,&#xD;&#xA;AC_RAMOGRUPPO AS ANA_RAMOGRUPPO,&#xD;&#xA;AC_COGNOME AS ANA_COGNOME,&#xD;&#xA;AC_SECONDO_COGNOME AS ANA_SECONDO_COGNOME,&#xD;&#xA;AC_NOME AS ANA_NOME,&#xD;&#xA;AC_SECONDO_NOME AS ANA_SECONDO_NOME,&#xD;&#xA;AC_CAPOGRUPPO AS ANA_CAPOGRUPPO,&#xD;&#xA;AC_UTENTE_INSERIMENTO AS ANA_UTENTE_INSERIMENTO,&#xD;&#xA;AC_DATA_INSERIMENTO AS ANA_DATA_INSERIMENTO,&#xD;&#xA;AC_UTENTE_VARIAZIONE AS ANA_UTENTE_VARIAZIONE,&#xD;&#xA;AC_DATA_VARIAZIONE AS ANA_DATA_VARIAZIONE,&#xD;&#xA;AC_TIPO_CONTROPARTE_01 AS ANA_ISCLIENTE,&#xD;&#xA;AC_TIPO_CONTROPARTE_02 AS ANA_ISAGENTE,&#xD;&#xA;AC_TIPO_CONTROPARTE_03 AS ANA_ISALTRO,&#xD;&#xA;AC_TIPO_CONTROPARTE_04 AS ANA_ISGARANTE,&#xD;&#xA;AC_TIPO_CONTROPARTE_05 AS ANA_ISDATIPO,&#xD;&#xA;AC_TIPO_CONTROPARTE_06 AS ANA_ISFORNITORE,&#xD;&#xA;AC_TIPO_CONTROPARTE_07 AS ANA_ISNOTAIO,&#xD;&#xA;AC_TIPO_CONTROPARTE_08 AS ANA_ISPERITO,&#xD;&#xA;AC_TIPO_CONTROPARTE_09 AS ANA_ISPROCURATORE,&#xD;&#xA;AC_TIPO_CONTROPARTE_10 AS ANA_ISDEBIT,&#xD;&#xA;AC_TIPO_CONTROPARTE_11 AS ANA_ISCOOBBLIGATO,&#xD;&#xA;AC_TIPO_CONTROPARTE_12 AS ANA_ISCONVENZIONATO,&#xD;&#xA;AC_TIPO_CONTROPARTE_13 AS ANA_ISDITTA,&#xD;&#xA;AC_TIPO_CONTROPARTE_14 AS ANA_ISFIRMAT,&#xD;&#xA;AC_TIPO_CONTROPARTE_15 AS ANA_ISFACTOR,&#xD;&#xA;AC_TIPO_CONTROPARTE_16 AS ANA_ISDELEGATO,&#xD;&#xA;AC_TIPO_CONTROPARTE_17 AS ANA_ISFONDOPE,&#xD;&#xA;AC_TIPO_CONTROPARTE_18 AS ANA_ISFINANZ,&#xD;&#xA;AC_TIPO_CONTROPARTE_19 AS ANA_ISDIPENDENTE,&#xD;&#xA;AC_TIPO_CONTROPARTE_20 AS ANA_ISESPAZI,&#xD;&#xA;AC_ISTRUTT_PRATICHE AS ANA_ISTRUTT_PRATICHE,&#xD;&#xA;AC_RILEV_QUALITA AS ANA_RILEV_QUALITA,&#xD;&#xA;AC_OFF_COMM_INTERNE AS ANA_OFF_COMM_INTERNE,&#xD;&#xA;AC_OFF_COMM_ESTERNE AS ANA_OFF_COMM_ESTERNE,&#xD;&#xA;AC_SERVIZI_ALTRI AS ANA_SERVIZI_ALTRI,&#xD;&#xA;AC_DATI_SENSIBILI AS ANA_DATI_SENSIBILI&#xD;&#xA;FROM toyodati.CCANAGR&#xD;&#xA;JOIN toyodati.LEPRA ON ( toyodati.CCANAGR.AC_CODICE = toyodati.LEPRA.LPC_FIRMATARIO )&#xD;&#xA;WHERE toyodati.LEPRA.LPC_NUM_PRATICA > 0 AND toyodati.LEPRA.LPC_FIRMATARIO > 0&quot;"/>
