 col11Encoded = java.util.Base64.getEncoder().encodeToString(&quot;VER_MODEL_NAME&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col12Encoded = java.util.Base64.getEncoder().encodeToString(&quot;VER_COMMERCIAL_NAME_PUB&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col13Encoded = java.util.Base64.getEncoder().encodeToString(&quot;VER_NUMBER_OF_DOOR&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col14Encoded = java.util.Base64.getEncoder().encodeToString(&quot;VER_ENGINE_CAPACITY&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col15Encoded = java.util.Base64.getEncoder().encodeToString(&quot;VER_ENGINE_TYPE&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col16Encoded = java.util.Base64.getEncoder().encodeToString(&quot;DATA_INSERT_TMI&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col17Encoded = java.util.Base64.getEncoder().encodeToString(&quot;DATA_DELETE_TMI&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col18Encoded = java.util.Base64.getEncoder().encodeToString(&quot;COD_MARCA_OCS&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col19Encoded = java.util.Base64.getEncoder().encodeToString(&quot;COD_MODELLO_OCS&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String col20Encoded = java.util.Base64.getEncoder().encodeToString(&quot;DATA_UPDATE_OCS&quot;.getBytes(&quot;UTF-8&quot;));&#xD;&#xA; String header = tabellaEncoded + KEY_SEP + key1Encoded + KEY_SEP + key2Encoded &#xD;&#xA;                 + FIELD_SEP + col1Encoded + FIELD_SEP + col2Encoded + FIELD_SEP + col3Encoded &#xD;&#xA;                 + FIELD_SEP + col4Encoded + FIELD_SEP + col5Encoded + FIELD_SEP + col6Encoded &#xD;&#xA;                 + FIELD_SEP + col7Encoded + FIELD_SEP + col8Encoded + FIELD_SEP + col9Encoded &#xD;&#xA;                 + FIELD_SEP + col10Encoded + FIELD_SEP + col11Encoded + FIELD_SEP + col12Encoded &#xD;&#xA;                 + FIELD_SEP + col13Encoded + FIELD_SEP + col14Encoded + FIELD_SEP + col15Encoded &#xD;&#xA;                 + FIELD_SEP + col16Encoded + FIELD_SEP + col17Encoded + FIELD_SEP + col18Encoded &#xD;&#xA;                 + FIELD_SEP + col19Encoded + FIELD_SEP + col20Encoded;&#xD;&#xA; java.util.ArrayList&lt;String> righe = new java.util.ArrayList&lt;String>();&#xD;&#xA; globalMap.put(&quot;payload_righe&quot;, righe);&#xD;&#xA; globalMap.put(&quot;payload_header&quot;, header);&#xD;&#xA;}&#xD;&#xA;String val1 = row4.VER_BRAND != null ? java.util.Base64.getEncoder().encodeToString(row4.VER_BRAND.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val2 = row4.CAT_CARLINE_CODE != null ? java.util.Base64.getEncoder().encodeToString(row4.CAT_CARLINE_CODE.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val3 = row4.CAT_CARLINE_NAME != null ? java.util.Base64.getEncoder().encodeToString(row4.CAT_CARLINE_NAME.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val4 = row4.SUB_CARLINE_CODE != null ? java.util.Base64.getEncoder().encodeToString(row4.SUB_CARLINE_CODE.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val5 = row4.SUB_CARLINE_NAME != null ? java.util.Base64.getEncoder().encodeToString(row4.SUB_CARLINE_NAME.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val6 = row4.GRA_GRADE_CODE != null ? java.util.Base64.getEncoder().encodeToString(row4.GRA_GRADE_CODE.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val7 = row4.GRA_GRADE != null ? java.util.Base64.getEncoder().encodeToString(row4.GRA_GRADE.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val8 = row4.SER_SERIES_NAME != null ? java.util.Base64.getEncoder().encodeToString(row4.SER_SERIES_NAME.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val9 = row4.SER_REVISION != null ? java.util.Base64.getEncoder().encodeToString(row4.SER_REVISION.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val10 = row4.VER_VERSION_CODE != null ? java.util.Base64.getEncoder().encodeToString(row4.VER_VERSION_CODE.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val11 = row4.VER_MODEL_NAME != null ? java.util.Base64.getEncoder().encodeToString(row4.VER_MODEL_NAME.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val12 = row4.VER_COMMERCIAL_NAME_PUB != null ? java.util.Base64.getEncoder().encodeToString(row4.VER_COMMERCIAL_NAME_PUB.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val13 = row4.VER_NUMBER_OF_DOOR != null ? java.util.Base64.getEncoder().encodeToString(row4.VER_NUMBER_OF_DOOR.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val14 = row4.VER_ENGINE_CAPACITY != null ? java.util.Base64.getEncoder().encodeToString(row4.VER_ENGINE_CAPACITY.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val15 = row4.VER_ENGINE_TYPE != null ? java.util.Base64.getEncoder().encodeToString(row4.VER_ENGINE_TYPE.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val16 = row4.DATA_INSERT_TMI != null ? java.util.Base64.getEncoder().encodeToString(row4.DATA_INSERT_TMI.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val17 = row4.DATA_DELETE_TMI != null ? java.util.Base64.getEncoder().encodeToString(row4.DATA_DELETE_TMI.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val18 = row4.COD_MARCA_OCS != null ? java.util.Base64.getEncoder().encodeToString(row4.COD_MARCA_OCS.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val19 = row4.COD_MODELLO_OCS != null ? java.util.Base64.getEncoder().encodeToString(row4.COD_MODELLO_OCS.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String val20 = row4.DATA_UPDATE_OCS != null ? java.util.Base64.getEncoder().encodeToString(row4.DATA_UPDATE_OCS.toString().getBytes(&quot;UTF-8&quot;)) : &quot;&quot;;&#xD;&#xA;String riga = val1 + FIELD_SEP + val2 + FIELD_SEP + val3 + FIELD_SEP + val4 &#xD;&#xA;           + FIELD_SEP + val5 + FIELD_SEP + val6 + FIELD_SEP + val7 + FIELD_SEP + val8 &#xD;&#xA;           + FIELD_SEP + val9 + FIELD_SEP + val10 + FIELD_SEP + val11 + FIELD_SEP + val12 &#xD;&#xA;           + FIELD_SEP + val13 + FIELD_SEP + val14 + FIELD_SEP + val15 + FIELD_SEP + val16 &#xD;&#xA;           + FIELD_SEP + val17 + FIELD_SEP + val18 + FIELD_SEP + val19 + FIELD_SEP + val20;&#xD;&#xA;java.util.ArrayList&lt;String> righe = (java.util.ArrayList&lt;String>) globalMap.get(&quot;payload_righe&quot;);&#xD;&#xA;righe.add(riga);"/>
