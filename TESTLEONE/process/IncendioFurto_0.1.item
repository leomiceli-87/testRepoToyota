    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;LE&quot;.equals(String.valueOf(globalMap.get(&quot;row3.tipo&quot;)))&#xD;&#xA;?&#xD;&#xA;&quot;UPDATE LECES SET &quot; +&#xD;&#xA;&quot;STATO = 'P', &quot; +&#xD;&#xA;&quot;DATA_PERFEZIONAMENTO = '&quot; + globalMap.get(&quot;row3.data&quot;) + &quot;' &quot; +&#xD;&#xA;&quot;WHERE ID = &quot; + globalMap.get(&quot;row3.id&quot;)&#xD;&#xA;:&#xD;&#xA;&quot;CO&quot;.equals(String.valueOf(globalMap.get(&quot;row3.tipo&quot;)))&#xD;&#xA;?&#xD;&#xA;&quot;UPDATE PLPRAT SET &quot; +&#xD;&#xA;&quot;STATO = 'P', &quot; +&#xD;&#xA;&quot;DATA_PERFEZIONAMENTO = '&quot; + globalMap.get(&quot;row3.data&quot;) + &quot;' &quot; +&#xD;&#xA;&quot;WHERE ID = &quot; + globalMap.get(&quot;row3.id&quot;)&#xD;&#xA;:&#xD;&#xA;&quot;SELECT 1&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
