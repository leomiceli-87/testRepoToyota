  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="680" posY="520">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="System.out.println(&quot;===== RESPONSE GATEWAY =====&quot;);&#xD;&#xA;String body = row2.Body&#xD;&#xA;    .replaceAll(&quot;[\\r\\n]+&quot;, &quot; &quot;)&#xD;&#xA;    .replaceAll(&quot;\\s+&quot;, &quot; &quot;)       &#xD;&#xA;    .trim();     &#xD;&#xA;System.out.println(body);&#xD;&#xA;System.out.println(&quot;===== END =====&quot;);&#xD;&#xA;if (body == null || body.trim().isEmpty()) {&#xD;&#xA;    System.out.println(&quot;Nessuna response dal Gateway ricevuta...&quot;);&#xD;&#xA;    return;&#xD;&#xA;}&#xD;&#xA;String[] rows = body.split(&quot;\n&quot;);&#xD;&#xA;if (rows.length == 0) {&#xD;&#xA;    return;&#xD;&#xA;}&#xD;&#xA;String[] headerFields = rows[0].split(&quot;\\|&quot;);&#xD;&#xA;int recordCount = 0;&#xD;&#xA;if (headerFields.length > 4) {&#xD;&#xA;    try {&#xD;&#xA;        recordCount = Integer.parseInt(headerFields[4]);&#xD;&#xA;    } catch (NumberFormatException e) {&#xD;&#xA;        recordCount = 0;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;if (recordCount == 0) {&#xD;&#xA;    return;&#xD;&#xA;}&#xD;&#xA;for (int i = 1; i &lt; rows.length; i++) {&#xD;&#xA;    String row = rows[i].trim();&#xD;&#xA;    if (row.isEmpty()) {&#xD;&#xA;        continue;&#xD;&#xA;    }&#xD;&#xA;    java.util.Map&lt;String, String> dataMap = new java.util.HashMap&lt;>();&#xD;&#xA;    String[] columns = row.split(&quot;\\|&quot;);&#xD;&#xA;    for (String col : columns) {&#xD;&#xA;        String[] kv = col.split(&quot;=&quot;, 2);&#xD;&#xA;        if (kv.length == 2) {&#xD;&#xA;            String key = kv[0].toLowerCase();&#xD;&#xA;            String value = kv[1];&#xD;&#xA;            try {&#xD;&#xA;                byte[] decoded = java.util.Base64.getDecoder().decode(value);&#xD;&#xA;                value = new String(decoded, &quot;UTF-8&quot;);&#xD;&#xA;            } catch (Exception e) {}&#xD;&#xA;            dataMap.put(key, value);&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    String numPratica = dataMap.get(&quot;raf_binumpraocs&quot;);&#xD;&#xA;&#x9;boolean leasing = (numPratica != null &amp;&amp; numPratica.startsWith(&quot;8&quot;));&#xD;&#xA;    String query = &quot;&quot;;&#xD;&#xA;    String tipologia = &quot;&quot;;&#xD;&#xA;    if (leasing) {&#xD;&#xA;        tipologia = &quot;LE&quot;;&#xD;&#xA;        String dataImmatr = dataMap.getOrDefault(&quot;raf_daimmaut&quot;, &quot;00000000&quot;);&#xD;&#xA;        String anno = &quot;0&quot;;&#xD;&#xA;        String mese = &quot;0&quot;;&#xD;&#xA;        if (!dataImmatr.isEmpty() &amp;&amp; Long.parseLong(dataImmatr) > 0) {&#xD;&#xA;            anno = dataImmatr.substring(0, 4);&#xD;&#xA;            mese = dataImmatr.substring(4, 6);&#xD;&#xA;        }&#xD;&#xA;        query = String.format(&#xD;&#xA;&#x9;&#x9;&#x9;&quot;UPDATE LECES SET LCE_TARGA = '%s', LCE_ANNO_IMMATR = %s, LCE_MESE_IMMATR = %s WHERE LCE_NUM_PRATICA = %s&quot;,&#xD;&#xA;&#x9;&#x9;&#x9;(dataMap.get(&quot;raf_vctaraut&quot;) != null ? dataMap.get(&quot;raf_vctaraut&quot;).replace(&quot;'&quot;, &quot;''&quot;) : &quot;&quot;),&#xD;&#xA;&#x9;&#x9;&#x9;anno, &#xD;&#xA;&#x9;&#x9;&#x9;mese, &#xD;&#xA;&#x9;&#x9;&#x9;numPratica&#xD;&#xA;         );&#xD;&#xA;    } else {&#xD;&#xA;        tipologia = &quot;CO&quot;;&#xD;&#xA;        String dataImmatr = dataMap.getOrDefault(&quot;raf_daimmaut&quot;, &quot;00000000&quot;);&#xD;&#xA;        String anno = &quot;0&quot;;&#xD;&#xA;        String dataMese = &quot;0&quot;;&#xD;&#xA;        if (!dataImmatr.isEmpty() &amp;&amp; Long.parseLong(dataImmatr) > 0) {&#xD;&#xA;            anno = dataImmatr.substring(2, 4);&#xD;&#xA;        }&#xD;&#xA;        query = String.format(&#xD;&#xA;&#x9;&#x9;&#x9;&quot;UPDATE PLPRAT SET PLC_AUTO_TARGA = '%s', PLC_AUTO_ANNO_IMMATRIC = %s, PLC_ANNO_MESE_IMMATR = %s WHERE  PLC_NUM_PRATICA = %s&quot;,&#xD;&#xA;&#x9;&#x9;&#x9;(dataMap.get(&quot;raf_vctaraut&quot;) != null ? dataMap.get(&quot;raf_vctaraut&quot;).replace(&quot;'&quot;, &quot;''&quot;) : &quot;&quot;), &#xD;&#xA;&#x9;&#x9;&#x9;anno, &#xD;&#xA;&#x9;&#x9;&#x9;dataMese, &#xD;&#xA;&#x9;&#x9;&#x9;numPratica&#xD;&#xA;        );&#xD;&#xA;    }&#xD;&#xA;&#x9;output_row.query = query;&#xD;&#xA;&#x9;output_row.num_pratica = Integer.parseInt(numPratica);&#xD;&#xA;}"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_1">
      <column key="false" length="0" name="query" nullable="true" precision="0" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="num_pratica" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
    </metadata>
  </node>
