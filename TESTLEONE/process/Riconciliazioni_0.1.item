  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="1040" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="System.out.println(&quot;===== CLEANING LOCAL DIRECTORY =====&quot;);&#xD;&#xA;java.io.File dir = new java.io.File(context.ftpLocalDirectory);&#xD;&#xA;java.io.File[] files = dir.listFiles();&#xD;&#xA;if (files != null) {&#xD;&#xA;    for (java.io.File f : files) {&#xD;&#xA;        if (f.isFile() &amp;&amp; f.getName().toLowerCase().endsWith(&quot;.xml&quot;)) {&#xD;&#xA;        &#x9;String name = f.getName().toLowerCase();&#xD;&#xA;        &#x9;f.delete();&#xD;&#xA;        &#x9;System.out.println(&quot;old file [&quot;+ name +&quot;] deleted successfully.&quot;);&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;System.out.println(&quot;===== END =====&quot;);"/>
