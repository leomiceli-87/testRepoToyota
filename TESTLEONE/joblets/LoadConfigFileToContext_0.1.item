      <elementParameter field="MEMO_JAVA" name="CODE_END" value="int count = 0;&#xA;java.util.Set&lt;java.util.Map.Entry&lt;Object,Object>> entries = context.entrySet();&#xA;for(java.util.Map.Entry&lt;Object,Object> entry : entries) {&#xA;    String key = entry.getKey().toString();&#xA;    String value = (entry.getValue() != null) &#xA;    &#x9;? entry.getValue().toString() : &quot;NULL&quot;;&#xA;    &#x9;count++;&#xA;        System.out.println(count + &quot;) &quot; + key + &quot; => &quot; + value);&#xA;}&#xA;System.out.println(&quot;=== (&quot; + count + &quot; loaded keys) ===&quot;);&#xA;System.out.println(&quot;===== END =====&quot;);"/>
      <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
      <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
      <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
      <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
      <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
      <metadata connector="FLOW" name="tJavaFlex_1"/>
