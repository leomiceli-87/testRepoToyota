      <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="context.gatewayCallUrl = input_row.gatewayCallUrl;&#xD;&#xA;context.gatewayCallBody = input_row.gatewayCallBody&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   .replaceAll(&quot;[\\r\\n]+&quot;, &quot; &quot;)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   .replaceAll(&quot;\\s+&quot;, &quot; &quot;)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   .trim();&#xA;context.userAgent = input_row.userAgent;&#xA;System.out.println(&quot;===== INVOKING GATEWAY =====&quot;);&#xA;System.out.println(&quot;URL => &quot; + input_row.gatewayCallUrl);&#xA;System.out.println(&quot;BODY => &quot; + input_row.gatewayCallBody);&#xA;System.out.println(&quot;USER-AGENT => &quot; + input_row.userAgent);&#xD;&#xA;System.out.println(&quot;===== END =====&quot;);"/>
