    <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="400" posY="240">
      <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
      <elementParameter field="MEMO_JAVA" name="CODE" value="String timestamp = java.time.LocalDateTime.now()&#xA;    .format(java.time.format.DateTimeFormatter.ofPattern(&quot;yyyyMMdd_HHmmss&quot;));&#xA;new java.io.File(context.logsDirectoryPath).mkdirs();&#xA;String logFile = context.logsDirectoryPath + &quot;/Job_&quot; + context.jobName + &quot;_&quot; + timestamp + &quot;.log&quot;;&#xA;if (globalMap.get(&quot;stdout_redirected&quot;) == null) {&#xA;    try {&#xA;        java.io.PrintStream console = System.out;&#xA;        java.io.FileOutputStream fos = new java.io.FileOutputStream(logFile, true);&#xA;        class TeePrintStream extends java.io.PrintStream {&#xA;            private java.io.PrintStream second;&#xA;            public TeePrintStream(java.io.OutputStream main, java.io.PrintStream second) throws Exception {&#xA;                super(main, true, &quot;UTF-8&quot;);&#xA;                this.second = second;&#xA;            }&#xA;            private String format(String level, String msg) {&#xA;                String ts = java.time.LocalDateTime.now()&#xA;                    .format(java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd HH:mm:ss&quot;));&#xA;                return ts + &quot; [&quot; + level + &quot;] [&quot; + jobName + &quot;] &quot; + msg;&#xA;            }&#xA;            @Override&#xA;            public void println(String x) {&#xA;                String level = &quot;INFO&quot;;&#xA;                if (x.startsWith(&quot;[ERROR]&quot;)) {&#xA;                    level = &quot;ERROR&quot;;&#xA;                    x = x.replaceFirst(&quot;\\[ERROR\\]\\s*&quot;, &quot;&quot;);&#xA;                } else if (x.startsWith(&quot;[WARN]&quot;)) {&#xA;                    level = &quot;WARN&quot;;&#xA;                    x = x.replaceFirst(&quot;\\[WARN\\]\\s*&quot;, &quot;&quot;);&#xA;                }&#xA;                String formatted = format(level, x);&#xA;                super.println(formatted);&#xA;                second.println(formatted);&#xA;            }&#xA;        }&#xA;        TeePrintStream tee = new TeePrintStream(fos, console);&#xA;        System.setOut(tee);&#xA;        System.setErr(tee);&#xA;        globalMap.put(&quot;stdout_redirected&quot;, true);&#xA;    } catch (Exception e) {&#xA;        e.printStackTrace();&#xA;    }&#xA;}"/>
      <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
      <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
      <metadata connector="FLOW" name="tJava_1"/>
